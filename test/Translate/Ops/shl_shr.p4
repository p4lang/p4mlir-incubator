// CHECK:           %[[var_res:.*]] = p4hir.variable ["res", init] : <!i32i>
// CHECK:           p4hir.assign %[[val_shlop]], %[[var_res]] : <!i32i>
// CHECK:           p4hir.return

action int_shl_bit() {
    int<32> lhs;
    bit<8> rhs;
    int<32> res = lhs << rhs;
}

